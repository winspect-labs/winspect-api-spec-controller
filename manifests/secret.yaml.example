# Example Secret for Winspect ApiSpec Controller
# Copy to secret.yaml, fill in values, then: kubectl apply -f secret.yaml
# In production, use external secrets (Sealed Secrets, External Secrets Operator, etc.)
apiVersion: v1
kind: Secret
metadata:
  name: winspect-apispec-controller-secret
  namespace: winspect-system
type: Opaque
stringData:
  APISPEC_ORG_ID: "your-org-id"
  APISPEC_API_KEY: "org_your-api-key"
  APISPEC_CENTRAL_API_URL: "https://api.winspect.io"
